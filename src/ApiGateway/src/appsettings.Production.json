{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      }
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "session": {
        "Destinations": {
          "session/0": { "Address": "http://session:8080" }
        }
      },
      "chat": {
        "Destinations": {
          "chat/0": { "Address": "http://chat:8080" }
        }
      },
      "mapitems": {
        "Destinations": {
          "mapitems/0": { "Address": "http://mapitems:8080" }
        }
      }
    }
  }
}
