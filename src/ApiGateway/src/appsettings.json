{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "CorsOrigins": [ "https://localhost:4200" ],

  "ReverseProxy": {
    "Routes": {
      "session-auth-route": {
        "ClusterId": "session",
        "Match": { "Path": "/api/v1/auth/{**catch-all}" }
      },
      "session-sessions-route": {
        "ClusterId": "session",
        "Match": { "Path": "/api/v1/sessions/{**catch-all}" }
      },
      "chat-hub-route": {
        "ClusterId": "chat",
        "Match": { "Path": "/hubs/chat/{**catch-all}" }
      },
      "chat-route": {
        "ClusterId": "chat",
        "Match": { "Path": "/api/v1/chat/{**catch-all}" }
      },
      "mapitems-hub-route": {
        "ClusterId": "mapitems",
        "Match": { "Path": "/hubs/mapitems/{**catch-all}" }
      },
      "mapitems-route": {
        "ClusterId": "mapitems",
        "Match": { "Path": "/api/v1/markers/{**catch-all}" }
      }
    },
    "Clusters": {
      "session": {
        "Destinations": {
          "session/0": { "Address": "https+http://session" }
        }
      },
      "chat": {
        "Destinations": {
          "chat/0": { "Address": "https+http://chat" }
        }
      },
      "mapitems": {
        "Destinations": {
          "mapitems/0": { "Address": "https+http://mapitems" }
        }
      }
    }
  }
}
